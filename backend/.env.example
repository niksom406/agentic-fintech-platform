# Application
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database (SQLite for local dev)
DATABASE_URL=sqlite:///./agentic_fintech.db

# LLM Providers
OPENAI_API_KEY=sk-your-key-here
GROQ_API_KEY=gsk_your-key-here

# LLM Settings
PRIMARY_LLM_MODEL=gpt-4o-mini
FALLBACK_LLM_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=1500
ENABLE_LLM_AGENTS=false

# LangSmith (optional tracing — leave blank to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-fintech-platform

# App settings
SEED_ON_STARTUP=true
AUDIT_EXPORT_DIR=./audit_exports
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production (Railway): set these in the host dashboard, not in git
# APP_ENV=production
# ENABLE_LLM_AGENTS=true
# CORS_ORIGINS=https://your-app.vercel.app
# Cloud hosts inject PORT automatically — do not hardcode BACKEND_PORT there

