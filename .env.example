# Root env file used by docker-compose.yml
# Copy to .env and fill in real values: cp .env.example .env
# Individual services also have their own .env.example (backend/, frontend/)
# for running without Docker.

# ── Backend ───────────────────────────────────────────────────────────────
APP_ENV=development
BACKEND_PORT=8000

DATABASE_URL=sqlite:///./agentic_fintech.db

OPENAI_API_KEY=sk-your-key-here
GROQ_API_KEY=gsk_your-key-here

PRIMARY_LLM_MODEL=gpt-4o-mini
FALLBACK_LLM_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=1500
ENABLE_LLM_AGENTS=false

# LangSmith (optional tracing — leave blank to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-fintech-platform

SEED_ON_STARTUP=true
AUDIT_EXPORT_DIR=./audit_exports
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ──────────────────────────────────────────────────────────────
# Must match the backend service name/port in docker-compose.yml
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
